#!/bin/bash
# Open the file path under a mouse click in nvim, inside a tmux popup —
# or, when no tmux server is attached (herdr has taken over), in a
# temporary herdr split pane instead.
# Bound to Option+click (M-MouseDown1Pane) in dot_tmux.conf.
#
# We get the whole clicked line + column (#{mouse_line} / #{mouse_x}) instead
# of #{mouse_word}, because the default word-separators split paths at / . : -
# and we don't want to change them (that would alter double-click selection).
#
#   $1 = #{mouse_line}   text of the clicked line
#   $2 = #{mouse_x}      column of the click
#   $3 = pane cwd        to resolve relative paths
#
# TMUX_OPENFILE_PRINT=1 prints the resolved target instead of opening (tests).
export PATH="$PATH:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

# herdr helpers: the focused pane is workspace(focused) → active_tab → pane(focused).
herdr_focused_pane() {
  local tab; tab=$(herdr workspace list 2>/dev/null \
    | jq -r '.result.workspaces[] | select(.focused) | .active_tab_id') || return 1
  [ -n "$tab" ] || return 1
  herdr pane list --workspace "${tab%%:*}" 2>/dev/null \
    | jq -re --arg tab "$tab" \
        '[.result.panes[] | select(.tab_id == $tab and .focused)][0].pane_id'
}

notify() {
  tmux display-message "$1" 2>/dev/null && return
  herdr notification show "$1" >/dev/null 2>&1
}

if [ "$1" = "--token" ]; then
  # Called from WezTerm's open-uri hook with the hyperlink text directly; the
  # cwd comes from the attached client's (or focused herdr pane's) active pane.
  token="$2"
  cwd=$(tmux display-message -p '#{pane_current_path}' 2>/dev/null)
  if [ -z "$cwd" ]; then
    pane=$(herdr_focused_pane) && cwd=$(herdr pane get "$pane" 2>/dev/null \
      | jq -r '.result.pane.foreground_cwd // .result.pane.cwd // empty')
  fi
  cwd="${cwd:-$HOME}"
else
  line="$1"; col="${2:-0}"; cwd="${3:-$HOME}"

  # Whitespace-delimited token covering the clicked column; fallback to the
  # first token containing a slash (useful when wide chars skew the column).
  token=$(LINE="$line" COL="$col" perl -CSDA -e '
    my $l = $ENV{LINE}; my $c = $ENV{COL} + 0;
    my @t; while ($l =~ /(\S+)/g) { push @t, [$-[0], $+[0], $1] }
    my $tok;
    for (@t) { if ($c >= $_->[0] && $c < $_->[1]) { $tok = $_->[2]; last } }
    if (!defined $tok) { for (@t) { if ($_->[2] =~ m{/}) { $tok = $_->[2]; last } } }
    print $tok // "";
  ')
fi
[ -n "$token" ] || exit 0

# Trim wrapping punctuation/quotes, then a trailing :line[:col] suffix.
token="${token#[\(\[\{\'\"\`<]}"
token="${token%[\)\]\}\'\"\`>,;]}"
lineno=""
case "$token" in
  *:[0-9]*)
    rest="${token##*[!0-9:]}"               # e.g. ":12:5" tail
    base="${token%"$rest"}$( : )"
    # split file:NN[:NN] -> file + first NN
    f="${token%%:[0-9]*}"
    n="${token#"$f":}"; n="${n%%[!0-9]*}"
    [ -n "$n" ] && { token="$f"; lineno="$n"; }
    ;;
esac
token="${token%:}"

# ~ expansion and relative-path resolution.
case "$token" in "~/"*) token="$HOME/${token#\~/}" ;; esac
case "$token" in /*) file="$token" ;; *) file="$cwd/$token" ;; esac

# git-diff style a/foo b/foo prefixes.
if [ ! -e "$file" ]; then
  case "$token" in
    a/*|b/*) [ -e "$cwd/${token#?/}" ] && file="$cwd/${token#?/}" ;;
  esac
fi

if [ ! -e "$file" ]; then
  notify "no file: $token"
  exit 0
fi

if [ -n "$TMUX_OPENFILE_PRINT" ]; then
  printf '%s%s\n' "$file" "${lineno:+ +$lineno}"
  exit 0
fi

# Images: just hand off to the macOS default app (Preview). Rendering images in
# the terminal via wezterm imgcat is a minefield through tmux (popups report a
# zero cell-pixel size → imgcat divide-by-zero panic), so don't bother.
case "${file##*.}" in
  png|PNG|jpg|JPG|jpeg|JPEG|gif|GIF|webp|WEBP|bmp|BMP|tif|tiff|TIFF|ico|ICO|svg|SVG|heic|HEIC|pdf|PDF)
    open "$file"
    exit 0
    ;;
esac

# Markdown: render to a self-contained HTML file and open it in the GUI browser,
# the same "open it in a real app" approach as images — not a terminal/TUI
# viewer. pandoc does the conversion; a little GitHub-ish CSS makes it readable.
case "${file##*.}" in
  md|MD|markdown|Markdown|MARKDOWN|mdown|mkd|mkdn)
    if command -v pandoc >/dev/null 2>&1; then
      out="/tmp/md-preview/$(basename "${file%.*}").html"
      mkdir -p /tmp/md-preview
      # GitHub Dark palette: #0d1117 (bg), #161b22 (panels), #e6edf3 (text),
      # #8b949e (muted), #30363d (borders), #58a6ff (links).
      css='
        html{background:#0d1117}
        body{max-width:820px;margin:40px auto;padding:0 20px;
          font:16px/1.6 -apple-system,"Hiragino Sans",sans-serif;
          background:#0d1117;color:#e6edf3}
        h1,h2,h3{color:#f0f6fc}
        h1,h2{border-bottom:1px solid #30363d;padding-bottom:.3em}
        code{background:#6e768166;padding:.2em .4em;border-radius:6px;
          font:90% ui-monospace,Menlo,monospace}
        pre{background:#161b22;padding:16px;border-radius:6px;overflow:auto}
        pre code{background:none;padding:0}
        blockquote{color:#8b949e;border-left:.25em solid #30363d;
          margin:0;padding:0 1em}
        table{border-collapse:collapse}td,th{border:1px solid #30363d;padding:6px 13px}
        th{background:#161b22}
        img{max-width:100%}a{color:#58a6ff}
        hr{border:0;border-top:1px solid #30363d}'
      if pandoc "$file" -s --metadata title="$(basename "$file")" \
           --highlight-style breezedark --katex \
           -H <(printf '<meta charset="utf-8"><style>%s</style>' "$css") \
           -o "$out" 2>/dev/null; then
        # Open in its own chromeless Chrome window (--app), popup-style, rather
        # than a new tab in the existing window. Invoke the binary directly so a
        # running Chrome just spawns the extra window instead of locking.
        chrome="/Applications/Google Chrome.app/Contents/MacOS/Google Chrome"
        if [ -x "$chrome" ]; then
          "$chrome" --app="file://$out" --window-size=1000,1150 >/dev/null 2>&1 &
        else
          open "$out"
        fi
        exit 0
      fi
    fi
    # pandoc missing or failed → fall through to nvim below.
    ;;
esac

if tmux list-clients 2>/dev/null | grep -q .; then
  # tmux is attached: centered popup, closes with nvim. Route through
  # run-shell so display-popup resolves a current client even when this
  # script was spawned from outside tmux (WezTerm's open-uri hook).
  if [ -n "$TMUX" ]; then
    tmux display-popup -d "$cwd" -xC -yC -w92% -h88% -E "nvim ${lineno:++$lineno} '$file'"
  else
    tmux run-shell -b "tmux display-popup -d '$cwd' -xC -yC -w92% -h88% -E \"nvim ${lineno:++$lineno} '$file'\""
  fi
elif pane=$(herdr_focused_pane); then
  # herdr has no popup primitive, so fake one: split the focused pane, zoom
  # the new pane to fill the tab, and exec nvim there — quitting nvim closes
  # the pane, which drops the zoom and restores the previous layout/focus.
  new=$(herdr pane split "$pane" --direction right --ratio 0.5 --cwd "$cwd" --focus 2>/dev/null \
    | jq -r '.result.pane.pane_id // empty')
  if [ -n "$new" ]; then
    herdr pane zoom "$new" --on >/dev/null 2>&1
    herdr pane run "$new" "exec nvim ${lineno:++$lineno} '$file'"
  else
    notify "tmux-open-file: herdr split failed"
  fi
else
  # last resort: no multiplexer at all — plain editor via a new WezTerm window.
  command -v wezterm >/dev/null 2>&1 \
    && wezterm cli spawn --new-window --cwd "$cwd" -- nvim ${lineno:++$lineno} "$file" >/dev/null 2>&1
fi
