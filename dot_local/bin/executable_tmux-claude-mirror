#!/bin/bash
# Read-only live mirror of another tmux pane, used by the Claude mosaic
# overview (tmux-claude-mosaic). Polls `tmux capture-pane` of the target pane
# and redraws it into this pane, with a state glyph + location in the pane
# border title. Never sends input to the target.
export PATH="$PATH:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

target="$1"
self="$TMUX_PANE"
# Read-only tile: ignore C-c / C-\ / C-z so the user can't accidentally kill or
# suspend a tile. The mosaic is closed via `prefix U`; Enter jumps to the pane.
trap '' INT QUIT TSTP

while :; do
  # Target gone? show a tombstone and let this tile close.
  if ! tmux display -p -t "$target" '#{pane_id}' >/dev/null 2>&1; then
    printf '\033[H\033[2J\033[2m[ended]\033[0m\n'
    sleep 3
    exit 0
  fi

  title=$(tmux display -p -t "$target" '#{pane_title}')
  loc=$(tmux display -p -t "$target" '#{session_name}:#{window_index}')
  case "$title" in
    ✳*) g='●' ;;
    *)  g='▶' ;;
  esac
  task="${title#* }"
  tmux select-pane -t "$self" -T "$g $loc  ${task:0:28}" 2>/dev/null

  w=$(tmux display -p -t "$self" '#{pane_width}')
  h=$(tmux display -p -t "$self" '#{pane_height}')
  # Capture WITH colors (-e), keep the last $h lines, and truncate each line to
  # $w *visible* columns without breaking the SGR escape sequences.
  # Capture WITH colors (-e), keep the last $h lines, then per line make it
  # readable on the dark tile: drop the faint/dim attribute and remap near-black
  # foregrounds (Claude uses black / dark grey for some text + badges that sink
  # into the tile bg) to a light grey — while leaving real background colors and
  # other colors intact — then truncate to $w *visible* columns (wide chars = 2)
  # without breaking SGR escapes.
  body=$(tmux capture-pane -p -e -t "$target" 2>/dev/null | tail -n "$h" \
    | W="$w" perl -CSDA -ne '
        sub rm {
          my @p = split /;/, $_[0]; my @o;
          for (my $i = 0; $i <= $#p; $i++) {
            if ($p[$i] eq "38" && $i+2 <= $#p && $p[$i+1] eq "5") {
              my $n = $p[$i+2] + 0;
              $n = 250 if ($n == 0 || $n == 16 || ($n >= 232 && $n <= 242));
              push @o, "38", "5", $n; $i += 2;
            } elsif ($p[$i] eq "38" && $i+1 <= $#p && $p[$i+1] eq "2") {
              my $e = ($i+4 <= $#p ? $i+4 : $#p); push @o, @p[$i..$e]; $i = $e;
            } elsif ($p[$i] eq "48" && $i+1 <= $#p && ($p[$i+1] eq "5" || $p[$i+1] eq "2")) {
              my $st = ($p[$i+1] eq "5" ? 2 : 4);
              my $e = ($i+$st <= $#p ? $i+$st : $#p); push @o, @p[$i..$e]; $i = $e;
            } elsif ($p[$i] eq "30") {
              push @o, "38", "5", "250";
            } elsif ($p[$i] eq "2") {
              next;            # drop faint/dim — it sinks on the dark tile
            } else { push @o, $p[$i]; }
          }
          return "" if !@o;
          return "\e[" . join(";", @o) . "m";
        }
        my $w = $ENV{W}; my $c = 0; my $o = "";
        while (/\G(\e\[([0-9;:?]*)([A-Za-z])|.)/gcs) {
          my $tok = $1;
          if (defined $3) { $tok = rm($2) if $3 eq "m"; $o .= $tok; next }
          my $cw = ($tok =~ /[\x{1100}-\x{115F}\x{2E80}-\x{A4CF}\x{AC00}-\x{D7A3}\x{F900}-\x{FAFF}\x{FE30}-\x{FE4F}\x{FF00}-\x{FF60}\x{FFE0}-\x{FFE6}]/) ? 2 : 1;
          last if $c + $cw > $w;
          $o .= $tok; $c += $cw;
        }
        print $o, "\e[0m\n";
      ')
  printf '\033[H\033[2J%s' "$body"

  # Wait up to 1s for a keypress on this (focused) tile. A plain Enter jumps to
  # the real Claude pane this tile mirrors and tears the mosaic down; any other
  # key just triggers an early refresh. Tiles that aren't focused get no input
  # and simply refresh on timeout.
  if read -rsn1 -t 1 ch 2>/dev/null && [ -z "$ch" ]; then
    if tmux list-panes -a -F '#{pane_id}' | grep -qxF "$target"; then
      tmux switch-client -t "$target"
      tmux select-window -t "$target"
      tmux select-pane -t "$target"
    fi
    tmux kill-session -t cc-mosaic 2>/dev/null
    exit 0
  fi
done
