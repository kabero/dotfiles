#!/bin/bash
# Briefly flash the current session name in a centered box. Hooked to
# client-session-changed (see dot_tmux.conf) so switching sessions shows where
# you landed. The popup auto-closes when the command exits (~0.6s).
export PATH="$PATH:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

name=$(tmux display-message -p '#{session_name}' 2>/dev/null)
[ -n "$name" ] || exit 0
inner="    $name    "

tmux display-popup -e "INNER=$inner" \
  -w "$(( ${#inner} + 2 ))" -h 3 -x C -y C -b rounded -S "fg=colour110" -E '
    printf "\033[1;38;5;117m%s\033[0m" "$INNER"
    sleep 0.35
  '
