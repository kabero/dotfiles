#!/bin/bash

ghq_root="$(ghq root)"
cur_sess=$(tmux display-message -p '#S' 2>/dev/null)
now=$(date +%s)

# Clean up all scratch files no matter how we exit (fzf cancel, error, etc.).
trap 'rm -f "$sess_file" "$att_file" "$cc_file"' EXIT

# Write active sessions to temp file for awk
sess_file=$(mktemp)
tmux list-sessions -F "#S" 2>/dev/null > "$sess_file" || true

# Build repo list: ghq repos + submodules + chezmoi
repo_list=$(ghq list)

# Append submodule paths
for gitmodules in "$ghq_root"/*/*/*/.gitmodules; do
  [ -f "$gitmodules" ] || continue
  repo="${gitmodules%/.gitmodules}"
  repo="${repo#$ghq_root/}"
  while IFS='=' read -r key val; do
    case "$key" in
      *path*)
        val=$(echo "$val" | sed 's/^[[:space:]]*//')
        repo_list="$repo_list
$repo/$val"
        ;;
    esac
  done < "$gitmodules"
done

repo_list="$repo_list
chezmoi"

# Mark active sessions
marked_repos=$(echo "$repo_list" | awk -v sf="$sess_file" '
BEGIN {
  while ((getline line < sf) > 0) s[line] = 1
  close(sf)
}
NF {
  repo = $0
  n = split(repo, parts, "/")
  if (n > 3) {
    sess = ""
    for (i = 4; i <= n; i++) sess = sess (i > 4 ? "/" : "") parts[i]
  } else {
    sess = parts[n]
  }
  if (sess in s) print "* " repo
  else print "  " repo
}')

active=$(echo "$marked_repos" | grep '^\* ')
inactive=$(echo "$marked_repos" | grep -v '^\* ')

# Add tmux sessions not tied to any ghq repo
matched_sessions=$(echo "$active" | sed 's/^\* //' | awk -F/ '{
  n = split($0, parts, "/")
  if (n > 3) {
    sess = ""
    for (i = 4; i <= n; i++) sess = sess (i > 4 ? "/" : "") parts[i]
  } else {
    sess = parts[n]
  }
  print sess
}')
orphan_sessions=$(tmux list-sessions -F "#S" 2>/dev/null | while read -r sess; do
  if ! echo "$matched_sessions" | grep -qxF "$sess"; then
    echo "* $sess"
  fi
done)
if [ -n "$orphan_sessions" ]; then
  active=$(printf '%s\n%s' "$active" "$orphan_sessions")
fi

# Order active sessions most-recently-visited first. tmux bumps
# session_last_attached every time you switch-client to a session, so sorting
# by it descending gives MRU order (current session at the top).
att_file=$(mktemp)
tmux list-sessions -F '#{session_last_attached} #{session_name}' 2>/dev/null > "$att_file"
active=$(echo "$active" | awk 'NF' | awk -v af="$att_file" -v cur="$cur_sess" '
  BEGIN {
    while ((getline l < af) > 0) {
      sp = index(l, " "); if (sp == 0) continue
      att[substr(l, sp + 1)] = substr(l, 1, sp - 1)
    }
    close(af)
  }
  {
    repo = $0; sub(/^\* /, "", repo); sub(/^  /, "", repo)
    n = split(repo, parts, "/")
    if (repo == "chezmoi") sess = "chezmoi"
    else if (n > 3) { sess = ""; for (i = 4; i <= n; i++) sess = sess (i > 4 ? "/" : "") parts[i] }
    else sess = parts[n]
    if (cur != "" && sess == cur) next   # drop the session we are already in
    printf "%s\t%s\n", (sess in att ? att[sess] : 0), $0
  }' | sort -t"$(printf '\t')" -k1,1 -rn | cut -f2-)

# Annotate lines whose tmux session has a Claude instance running (hook-free,
# via tmux-claude-status). The summary is appended as a hidden TSV field so the
# existing selection-parsing below is unaffected.
cc_file=$(mktemp)
tmux-claude-status --by-session > "$cc_file" 2>/dev/null

# Reformat each row so the repo name leads (bold), the owner trails (dimmed),
# and active sessions get a blue dot + any Claude summary. The canonical repo
# path is appended as a hidden trailing TSV field for the resolution below;
# fzf shows only field 1 (--with-nth=1) but still searches the whole line.
selected=$( (echo "$active"; echo "$inactive") | awk 'NF' | \
  awk -v cf="$cc_file" -v af="$att_file" -v now="$now" '
    # Color each Claude state token to match the status bar / dashboard:
    # working (>) green, done (check) yellow, idle (dot) grey.
    function colorcc(s,   k, toks, out, t, g) {
      k = split(s, toks, " ")
      for (t = 1; t <= k; t++) {
        if (toks[t] == "") continue
        if (index(toks[t], "\xe2\x96\xb6") == 1)      g = "\033[1;38;5;82m"
        else if (index(toks[t], "\xe2\x9c\x93") == 1) g = "\033[1;38;5;226m"
        else                                          g = "\033[38;5;250m"
        out = out (out == "" ? "" : " ") g toks[t] "\033[0m"
      }
      return out
    }
    # Compact "time since last attached" tag, e.g. 45s / 12m / 3h / 2d.
    function ageof(t,   d) {
      if (t == "" || t + 0 == 0 || now + 0 == 0) return ""
      d = now - t; if (d < 0) d = 0
      if (d < 60)    return d "s"
      if (d < 3600)  return int(d / 60) "m"
      if (d < 86400) return int(d / 3600) "h"
      return int(d / 86400) "d"
    }
    BEGIN {
      while ((getline line < cf) > 0) {
        split(line, a, "\t"); if (a[1] != "") m[a[1]] = a[2]
      }
      close(cf)
      while ((getline line < af) > 0) {
        sp = index(line, " "); if (sp == 0) continue
        att[substr(line, sp + 1)] = substr(line, 1, sp - 1)
      }
      close(af)
      R="\033[0m"; DOT="\033[38;5;75m"; ON="\033[1;38;5;255m";
      OFF="\033[38;5;250m"; OWN="\033[38;5;243m"; AGE="\033[38;5;240m";
      maxl=0; maxa=0; cnt=0
    }
    {
      isact = ($0 ~ /^\* /) ? 1 : 0
      repo = $0; sub(/^\* /, "", repo); sub(/^  /, "", repo)
      n = split(repo, p, "/")
      if (repo == "chezmoi") { nm="chezmoi"; ow=""; ss="chezmoi" }
      else if (n == 1) { nm=repo; ow=""; ss=repo }
      else {
        ow = p[2]; nm = ""
        for (i = 3; i <= n; i++) nm = nm (i > 3 ? "/" : "") p[i]
        if (n > 3) { ss = ""; for (i = 4; i <= n; i++) ss = ss (i > 4 ? "/" : "") p[i] }
        else ss = p[n]
      }
      cnt++
      A[cnt]=isact; NM[cnt]=nm; OW[cnt]=ow; PA[cnt]=repo; CCv[cnt]=(ss in m ? m[ss] : "")
      AGv[cnt] = (ss in att ? ageof(att[ss]) : "")
      labw = (ow == "" ? length(nm) : length(ow) + 1 + length(nm))
      if (labw > maxl) maxl = labw
      if (length(AGv[cnt]) > maxa) maxa = length(AGv[cnt])
    }
    END {
      for (i = 1; i <= cnt; i++) {
        labw = (OW[i] == "" ? length(NM[i]) : length(OW[i]) + 1 + length(NM[i]))
        pad=""; for (j = labw; j < maxl; j++) pad = pad " "
        mark = A[i] ? (DOT "\xe2\x97\x8f" R) : " "
        nmc  = A[i] ? (ON NM[i] R) : (OFF NM[i] R)
        lab  = (OW[i] == "" ? nmc : OWN OW[i] "/" R nmc)
        line = mark "  " lab pad
        if (maxa > 0) {
          asp=""; for (j = length(AGv[i]); j < maxa; j++) asp = asp " "
          line = line "  " asp (AGv[i] == "" ? "" : AGE AGv[i] R)
        }
        if (CCv[i] != "") line = line "  " colorcc(CCv[i])
        printf "%s\t%s\n", line, PA[i]
      }
    }' | \
  fzf --ansi --height 100% --layout reverse \
      --border rounded --border-label " session / repo " \
      --color "fg:-1,bg:-1,fg+:255,bg+:236,hl:75,hl+:75,pointer:75,marker:75,border:238,label:75,prompt:75,info:243,header:243,gutter:-1,spinner:75" \
      --pointer "▌" --prompt "> " \
      --delimiter='\t' --with-nth=1 --highlight-line) || exit 0

selected="${selected##*$'\t'}"

if [ "$selected" = "chezmoi" ]; then
  session="chezmoi"
  dir="$HOME/.local/share/chezmoi"
else
  dir="$ghq_root/$selected"
  depth=$(echo "$selected" | awk -F/ '{print NF}')
  if [ "$depth" -gt 3 ]; then
    session=$(echo "$selected" | awk -F/ '{for(i=4;i<=NF;i++) printf "%s%s",$i,(i<NF?"/":"")}')
  else
    session=$(basename "$selected")
  fi
fi

tmux has-session -t "$session" 2>/dev/null || tmux new-session -d -c "$dir" -s "$session"
tmux switch-client -t "$session"
