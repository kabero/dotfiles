#!/bin/bash
set -e

ghq_root="$(ghq root)"

# Existing tmux sessions (for marking active repos)
active_sessions=$(tmux list-sessions -F "#S" 2>/dev/null || true)

# Build repo list with active session markers
repos=$(
  echo "chezmoi"
  ghq list
  ghq list | while read -r repo; do
    if [ -f "$ghq_root/$repo/.gitmodules" ]; then
      grep '^\s*path\s*=' "$ghq_root/$repo/.gitmodules" | sed "s/.*=\s*//" | while read -r sm_path; do
        echo "$repo/$sm_path"
      done
    fi
  done
)

# Mark repos that have an active tmux session
marked_repos=$(echo "$repos" | while read -r repo; do
  session=$(echo "$repo" | awk -F/ '{ print $(NF-1)"/"$NF }')
  if [ "$repo" = "chezmoi" ]; then
    session="chezmoi"
  fi
  if echo "$active_sessions" | grep -qxF "$session"; then
    echo "* $repo"
  else
    echo "  $repo"
  fi
done)

# Preview script: show branch + recent log
preview_cmd='
  repo="{}"
  repo=$(echo "$repo" | sed "s/^[* ] //")
  ghq_root="$(ghq root)"
  if [ "$repo" = "chezmoi" ]; then
    dir="$HOME/.local/share/chezmoi"
  else
    dir="$ghq_root/$repo"
  fi
  if [ -d "$dir/.git" ] || [ -f "$dir/.git" ]; then
    branch=$(git -C "$dir" branch --show-current 2>/dev/null || echo "detached")
    echo "Branch: $branch"
    echo ""
    git -C "$dir" log --oneline --graph -10 2>/dev/null
  fi
'

selected=$(echo "$marked_repos" | \
  awk '!seen[$0]++ && NF' | \
  fzf --height 100% --layout reverse --border \
      --prompt "session/repo > " \
      --preview "$preview_cmd" \
      --preview-window right:50%:wrap)

[ -z "$selected" ] && exit 0

# Strip marker prefix
selected=$(echo "$selected" | sed 's/^[* ] //')

if [ "$selected" = "chezmoi" ]; then
  session="chezmoi"
  dir="$HOME/.local/share/chezmoi"
else
  session=$(echo "$selected" | awk -F/ '{ print $(NF-1)"/"$NF }')
  dir="$ghq_root/$selected"
fi

tmux has-session -t "$session" 2>/dev/null || tmux new-session -d -c "$dir" -s "$session"
tmux switch-client -t "$session"
