#!/bin/bash
set -e

ghq_root="$(ghq root)"
active_sessions=$(tmux list-sessions -F "#S" 2>/dev/null || true)

# Build repo list with submodules, mark active sessions
ghq_repos=$(ghq list)

# Find all .gitmodules in one shot and extract submodule paths
submodules=$(find "$ghq_root" -maxdepth 4 -name .gitmodules 2>/dev/null | while read -r f; do
  repo="${f%/.gitmodules}"
  repo="${repo#$ghq_root/}"
  grep '^\s*path\s*=' "$f" | sed "s/.*=\s*//" | while read -r sm_path; do
    echo "$repo/$sm_path"
  done
done)

marked_repos=$(
  {
    echo "$ghq_repos"
    [ -n "$submodules" ] && echo "$submodules"
    echo "chezmoi"
  } | awk -v sessions="$active_sessions" '
  BEGIN {
    n = split(sessions, arr, "\n")
    for (i = 1; i <= n; i++) s[arr[i]] = 1
  }
  {
    repo = $0
    n = split(repo, parts, "/")
    if (n >= 2) sess = parts[n-1] "/" parts[n]
    else sess = repo
    if (sess in s) print "* " repo
    else print "  " repo
  }
')

selected=$(echo "$marked_repos" | \
  awk 'NF' | \
  fzf --height 100% --layout reverse --border \
      --prompt "session/repo > ")

[ -z "$selected" ] && exit 0

selected="${selected#\* }"
selected="${selected#  }"

if [ "$selected" = "chezmoi" ]; then
  session="chezmoi"
  dir="$HOME/.local/share/chezmoi"
else
  session=$(echo "$selected" | awk -F/ '{ print $(NF-1)"/"$NF }')
  dir="$ghq_root/$selected"
fi

tmux has-session -t "$session" 2>/dev/null || tmux new-session -d -c "$dir" -s "$session"
tmux switch-client -t "$session"
