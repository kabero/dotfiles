#!/bin/bash

ghq_root="$(ghq root)"

# Write active sessions to temp file for awk
sess_file=$(mktemp)
tmux list-sessions -F "#S" 2>/dev/null > "$sess_file" || true

# Build repo list: ghq repos + submodules + chezmoi
repo_list=$(ghq list)

# Append submodule paths
for gitmodules in "$ghq_root"/*/*/*/.gitmodules; do
  [ -f "$gitmodules" ] || continue
  repo="${gitmodules%/.gitmodules}"
  repo="${repo#$ghq_root/}"
  while IFS='=' read -r key val; do
    case "$key" in
      *path*)
        val=$(echo "$val" | sed 's/^[[:space:]]*//')
        repo_list="$repo_list
$repo/$val"
        ;;
    esac
  done < "$gitmodules"
done

repo_list="$repo_list
chezmoi"

# Mark active sessions
marked_repos=$(echo "$repo_list" | awk -v sf="$sess_file" '
BEGIN {
  while ((getline line < sf) > 0) s[line] = 1
  close(sf)
}
NF {
  repo = $0
  n = split(repo, parts, "/")
  if (n > 3) {
    sess = ""
    for (i = 4; i <= n; i++) sess = sess (i > 4 ? "/" : "") parts[i]
  } else {
    sess = parts[n]
  }
  if (sess in s) print "* " repo
  else print "  " repo
}')

rm -f "$sess_file"

active=$(echo "$marked_repos" | grep '^\* ')
inactive=$(echo "$marked_repos" | grep -v '^\* ')

# Add tmux sessions not tied to any ghq repo
matched_sessions=$(echo "$active" | sed 's/^\* //' | awk -F/ '{
  n = split($0, parts, "/")
  if (n > 3) {
    sess = ""
    for (i = 4; i <= n; i++) sess = sess (i > 4 ? "/" : "") parts[i]
  } else {
    sess = parts[n]
  }
  print sess
}')
orphan_sessions=$(tmux list-sessions -F "#S" 2>/dev/null | while read -r sess; do
  if ! echo "$matched_sessions" | grep -qxF "$sess"; then
    echo "* $sess"
  fi
done)
if [ -n "$orphan_sessions" ]; then
  active=$(printf '%s\n%s' "$active" "$orphan_sessions")
fi
fzf_out=$( (echo "$active"; echo "$inactive") | \
  awk 'NF' | \
  fzf --height 100% --layout reverse --border \
      --expect=ctrl-g \
      --header 'C-g: jump back to last session' \
      --prompt "session/repo > ") || exit 0

# <c-g><c-g>: the first C-g opens this popup; a second C-g jumps straight
# back to the previously-active session without picking anything.
key=$(printf '%s\n' "$fzf_out" | head -n 1)
if [ "$key" = "ctrl-g" ]; then
  tmux switch-client -l 2>/dev/null || true
  exit 0
fi

selected=$(printf '%s\n' "$fzf_out" | sed -n '2p')

selected="${selected#\* }"
selected="${selected#  }"

if [ "$selected" = "chezmoi" ]; then
  session="chezmoi"
  dir="$HOME/.local/share/chezmoi"
else
  dir="$ghq_root/$selected"
  depth=$(echo "$selected" | awk -F/ '{print NF}')
  if [ "$depth" -gt 3 ]; then
    session=$(echo "$selected" | awk -F/ '{for(i=4;i<=NF;i++) printf "%s%s",$i,(i<NF?"/":"")}')
  else
    session=$(basename "$selected")
  fi
fi

tmux has-session -t "$session" 2>/dev/null || tmux new-session -d -c "$dir" -s "$session"
tmux switch-client -t "$session"
