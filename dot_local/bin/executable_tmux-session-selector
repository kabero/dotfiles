#!/bin/bash
set -e

ghq_root="$(ghq root)"
active_sessions=$(tmux list-sessions -F "#S" 2>/dev/null || true)

# Build repo list (with submodules) and mark active sessions in one pass
ghq_repos=$(ghq list)
marked_repos=$(
  echo "$ghq_repos" | while read -r repo; do
    session=$(echo "$repo" | awk -F/ '{ print $(NF-1)"/"$NF }')
    if echo "$active_sessions" | grep -qxF "$session"; then
      echo "* $repo"
    else
      echo "  $repo"
    fi
    if [ -f "$ghq_root/$repo/.gitmodules" ]; then
      grep '^\s*path\s*=' "$ghq_root/$repo/.gitmodules" | sed "s/.*=\s*//" | while read -r sm_path; do
        sm_session=$(echo "$repo/$sm_path" | awk -F/ '{ print $(NF-1)"/"$NF }')
        if echo "$active_sessions" | grep -qxF "$sm_session"; then
          echo "* $repo/$sm_path"
        else
          echo "  $repo/$sm_path"
        fi
      done
    fi
  done
  # chezmoi
  if echo "$active_sessions" | grep -qxF "chezmoi"; then
    echo "* chezmoi"
  else
    echo "  chezmoi"
  fi
)

preview_cmd='
  repo="{}"
  repo=$(echo "$repo" | sed "s/^[* ] //")
  ghq_root="$(ghq root)"
  if [ "$repo" = "chezmoi" ]; then
    dir="$HOME/.local/share/chezmoi"
  else
    dir="$ghq_root/$repo"
  fi
  if [ -d "$dir/.git" ] || [ -f "$dir/.git" ]; then
    branch=$(git -C "$dir" branch --show-current 2>/dev/null || echo "detached")
    echo "Branch: $branch"
    echo ""
    status=$(git -C "$dir" status --short 2>/dev/null)
    if [ -n "$status" ]; then
      echo "$status"
    else
      echo "(clean)"
    fi
  fi
'

selected=$(echo "$marked_repos" | \
  awk 'NF' | \
  fzf --height 100% --layout reverse --border \
      --prompt "session/repo > " \
      --preview "$preview_cmd" \
      --preview-window right:50%:wrap)

[ -z "$selected" ] && exit 0

selected=$(echo "$selected" | sed 's/^[* ] //')

if [ "$selected" = "chezmoi" ]; then
  session="chezmoi"
  dir="$HOME/.local/share/chezmoi"
else
  session=$(echo "$selected" | awk -F/ '{ print $(NF-1)"/"$NF }')
  dir="$ghq_root/$selected"
fi

tmux has-session -t "$session" 2>/dev/null || tmux new-session -d -c "$dir" -s "$session"
tmux switch-client -t "$session"
