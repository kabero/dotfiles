#!/bin/bash
set -e

ghq_root="$(ghq root)"
active_sessions=$(tmux list-sessions -F "#S" 2>/dev/null || true)

# Build repo list with submodules
repo_list=$(
  ghq list
  ghq list | while read -r repo; do
    if [ -f "$ghq_root/$repo/.gitmodules" ]; then
      grep '^\s*path\s*=' "$ghq_root/$repo/.gitmodules" | sed "s/.*=\s*//" | while read -r sm_path; do
        echo "$repo/$sm_path"
      done
    fi
  done
  echo "chezmoi"
)

# Mark active sessions with awk (no per-line fork)
marked_repos=$(echo "$repo_list" | awk -v sessions="$active_sessions" '
  BEGIN {
    n = split(sessions, arr, "\n")
    for (i = 1; i <= n; i++) s[arr[i]] = 1
  }
  {
    repo = $0
    # extract owner/name from path
    n = split(repo, parts, "/")
    if (n >= 2) sess = parts[n-1] "/" parts[n]
    else sess = repo
    if (sess in s) print "* " repo
    else print "  " repo
  }
')

preview_cmd='
  repo="{}"
  repo="${repo#\* }"
  repo="${repo#  }"
  ghq_root="$(ghq root)"
  if [ "$repo" = "chezmoi" ]; then
    dir="$HOME/.local/share/chezmoi"
  else
    dir="$ghq_root/$repo"
  fi
  if [ -d "$dir/.git" ] || [ -f "$dir/.git" ]; then
    echo "Branch: $(git -C "$dir" branch --show-current 2>/dev/null || echo "detached")"
    echo ""
    status=$(git -C "$dir" status --short 2>/dev/null)
    if [ -n "$status" ]; then
      echo "$status"
    else
      echo "(clean)"
    fi
  fi
'

selected=$(echo "$marked_repos" | \
  awk 'NF' | \
  fzf --height 100% --layout reverse --border \
      --prompt "session/repo > " \
      --preview "$preview_cmd" \
      --preview-window right:50%:wrap)

[ -z "$selected" ] && exit 0

selected="${selected#\* }"
selected="${selected#  }"

if [ "$selected" = "chezmoi" ]; then
  session="chezmoi"
  dir="$HOME/.local/share/chezmoi"
else
  session=$(echo "$selected" | awk -F/ '{ print $(NF-1)"/"$NF }')
  dir="$ghq_root/$selected"
fi

tmux has-session -t "$session" 2>/dev/null || tmux new-session -d -c "$dir" -s "$session"
tmux switch-client -t "$session"
