#!/bin/bash

ghq_root="$(ghq root)"
active_sessions=$(tmux list-sessions -F "#S" 2>/dev/null || true)

# Build repo list: ghq repos + submodules + chezmoi
repo_list=$(ghq list)

# Append submodule paths
for gitmodules in "$ghq_root"/*/*/*/.gitmodules; do
  [ -f "$gitmodules" ] || continue
  repo="${gitmodules%/.gitmodules}"
  repo="${repo#$ghq_root/}"
  while IFS='=' read -r key val; do
    case "$key" in
      *path*)
        val="${val#"${val%%[![:space:]]*}"}"
        repo_list="$repo_list
$repo/$val"
        ;;
    esac
  done < "$gitmodules"
done

repo_list="$repo_list
chezmoi"

# Mark active sessions
marked_repos=$(echo "$repo_list" | awk -v sessions="$active_sessions" '
BEGIN {
  n = split(sessions, arr, "\n")
  for (i = 1; i <= n; i++) s[arr[i]] = 1
}
NF {
  repo = $0
  n = split(repo, parts, "/")
  sess = parts[n]
  if (sess in s) print "* " repo
  else print "  " repo
}')

selected=$(echo "$marked_repos" | \
  fzf --height 100% --layout reverse --border \
      --prompt "session/repo > ") || exit 0

selected="${selected#\* }"
selected="${selected#  }"

if [ "$selected" = "chezmoi" ]; then
  session="chezmoi"
  dir="$HOME/.local/share/chezmoi"
else
  session=$(basename "$selected")
  dir="$ghq_root/$selected"
fi

tmux has-session -t "$session" 2>/dev/null || tmux new-session -d -c "$dir" -s "$session"
tmux switch-client -t "$session"
