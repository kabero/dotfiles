#!/bin/bash
set -e

ghq_root="$(ghq root)"

sessions=$(tmux list-sessions -F "#S" 2>/dev/null | sed 's/^/* /' || true)

# List ghq repos + submodules within them
repos=$(
  echo "chezmoi"
  ghq list
  ghq list | while read -r repo; do
    dir="$ghq_root/$repo"
    if [ -f "$dir/.gitmodules" ]; then
      git -C "$dir" submodule --quiet foreach --recursive 'echo "'"$repo"'/$sm_path"'
    fi
  done
)

selected=$( (echo "$sessions"; echo "$repos") | \
  awk '!seen[$0]++ && NF' | \
  fzf --height 100% --layout reverse --border --prompt "session/repo > ")

[ -z "$selected" ] && exit 0

if echo "$selected" | grep -q '^\* '; then
  session=$(echo "$selected" | sed 's/^\* //')
  tmux switch-client -t "$session"
elif [ "$selected" = "chezmoi" ]; then
  session="chezmoi"
  dir="$HOME/.local/share/chezmoi"
  tmux has-session -t "$session" 2>/dev/null || tmux new-session -d -c "$dir" -s "$session"
  tmux switch-client -t "$session"
else
  # Use owner/repo as session name to avoid collisions (e.g. github.com/user/repo -> user/repo)
  session=$(echo "$selected" | awk -F/ '{ print $(NF-1)"/"$NF }')
  dir="$ghq_root/$selected"
  tmux has-session -t "$session" 2>/dev/null || tmux new-session -d -c "$dir" -s "$session"
  tmux switch-client -t "$session"
fi
