#!/bin/bash
# Claude mosaic ("command room"): tile a read-only live view of every running
# Claude Code pane into ONE WINDOW of the current session, so you can eyeball
# all agents at once. It's a window (not a separate session) on purpose: window
# switches don't touch tmux's last-session, so prefix-l / C-g C-g still jump to
# your real previous session, and there's no phantom session to get "not found"
# after closing. Toggle with `prefix m` (see dot_tmux.conf).
export PATH="$PATH:/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin"

WINNAME=cc-mosaic
CAP=16   # tmux can't tile arbitrarily many panes; cap and report the rest.

# Toggle: if we're already in the mosaic window, close it (kill-window returns
# to the previous window in this session — no session switch, last-session kept).
if [ "$(tmux show-options -wqv @ccmosaic 2>/dev/null)" = 1 ]; then
  tmux kill-window
  exit 0
fi

# Collect Claude pane ids (field 4 of the raw status output).
targets=()
while IFS= read -r p; do
  [ -n "$p" ] && targets+=("$p")
done < <(tmux-claude-status | awk -F'\t' '{print $4}')

if [ "${#targets[@]}" -eq 0 ]; then
  tmux display-message "No Claude Code instances running."
  exit 0
fi

# Drop any stale mosaic windows (e.g. left in another session) before rebuilding.
tmux list-windows -a -F '#{window_id} #{@ccmosaic}' 2>/dev/null \
  | awk '$2 == 1 {print $1}' | while read -r w; do tmux kill-window -t "$w" 2>/dev/null; done

# Build the mosaic as a fresh, detached window in the CURRENT session.
win=$(tmux new-window -d -P -F '#{window_id}' -n "$WINNAME" \
  "exec tmux-claude-mirror ${targets[0]}")

n=1
for t in "${targets[@]:1}"; do
  [ "$n" -ge "$CAP" ] && break
  tmux split-window -t "$win" "exec tmux-claude-mirror $t" 2>/dev/null \
    && tmux select-layout -t "$win" tiled >/dev/null 2>&1
  n=$((n + 1))
done

tmux set-option -w -t "$win" @ccmosaic 1
# Bright default foreground (same as a real Claude pane) so the bulk "default
# fg" text isn't dimmed; near-black/faint text is brightened in the mirror.
tmux set-option -w -t "$win" window-style "default,bg=colour234"
tmux set-option -w -t "$win" window-active-style "default,bg=colour233"
tmux set-option -w -t "$win" pane-border-status top
# The global pane-border-style uses a near-black fg, which would make the title
# (state + location + task) invisible — override with readable colors here.
tmux set-option -w -t "$win" pane-border-style "fg=colour240,bg=colour234"
tmux set-option -w -t "$win" pane-active-border-style "fg=colour110,bg=colour233"
# Border label: state glyph (colored by @ccst) + location (soft blue) + task.
#   ▶ green working   ✓ yellow just-finished   ● cyan idle
tmux set-option -w -t "$win" pane-border-format ' #{?#{==:#{@ccst},work},#[fg=colour82]▶,#{?#{==:#{@ccst},done},#[fg=colour226]✓,#[fg=colour110]●}} #[fg=colour111,bold]#{@ccloc}#[default] #[fg=colour250]#{pane_title}#[default] '
tmux set-option -w -t "$win" automatic-rename off
tmux select-layout -t "$win" tiled

if [ "${#targets[@]}" -gt "$CAP" ]; then
  tmux display-message "mosaic: showing $CAP of ${#targets[@]} Claude panes"
fi
# CLAUDE_MOSAIC_NOSWITCH lets tests build without yanking the user's view.
[ -z "$CLAUDE_MOSAIC_NOSWITCH" ] && tmux select-window -t "$win"
