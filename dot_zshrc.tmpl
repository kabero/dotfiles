# initialize
function command_exists() {
    command -v "$1" >/dev/null 2>&1
}

z() {
    unset -f z
    eval "$(zoxide init zsh)"
    __zoxide_z "$@"
}

gh() {
    unset -f gh
    eval "$(gh completion -s zsh)"
    gh "$@"
}

direnv() {
    unset -f direnv
    eval "$(direnv hook zsh)"
    direnv "$@"
}

command_exists starship && eval "$(starship init zsh)"

# fzf
if command_exists fzf; then
    [ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
    export FZF_COMPLETION_TRIGGER=","
    export FZF_DEFAULT_COMMAND='rg --files --hidden --follow --glob "!**/.git/*" --glob "!**/node_modules/*" --glob "!**/vendor/*" --glob "!**/dist/*"'
    export FZF_DEFAULT_OPTS="
    --height 50%
    --reverse
    --prompt='[file] > '
    --pointer='>'
    --marker='*'
    --ansi
    --color=fg:#f8f8f2,bg:#282a36,hl:#bd93f9
    --color=fg+:#f8f8f2,bg+:#282a36,hl+:#bd93f9
    --color=info:#ffb86c,prompt:#50fa7b,pointer:#ff79c6
    --color=marker:#ff79c6,spinner:#ffb86c,header:#6272a4
    --bind=ctrl-k:kill-line,ctrl-d:preview-down,ctrl-u:preview-up
    --preview-window=right:60%:wrap
    --border=rounded
    --margin=1
    --padding=1
    "

    # for finding files in current directories
    export FZF_CTRL_T_COMMAND='rg --files --hidden --follow --glob "!**/.git/*" --glob "!**/node_modules/*" --glob "!**/vendor/*" --glob "!**/dist/*"'
    export FZF_CTRL_T_OPTS="--prompt='[file] > '"

    # Enhanced <c-r>
    function select-history() {
        local original_buffer=$BUFFER
        local query=$LBUFFER
        local selected=$(history -n -r 1 | awk '!seen[$0]++' | fzf +m --query "$query" --prompt="[cmd] > " --exact)
        if [ -n "$selected" ]; then
            BUFFER=$selected
        else
            BUFFER=$original_buffer
        fi
        CURSOR=$#BUFFER
        zle redisplay
    }
    zle -N select-history
    bindkey '^r' select-history

    # history search by keyword
    h() {
        local selected=$(history -n -r 1 | awk '!seen[$0]++' | grep "$1" | fzf +m --prompt="[$1] > " --exact --preview='echo {} | sed "s/ -/\n  -/g"' --preview-window=down:70%:wrap)
        if [ -n "$selected" ]; then
            print -z "$selected"
        fi
    }

    # Enhanced <c-t>
    function select-file() {
        local result=$(rg --files --hidden --follow --glob "!**/.git/*" | fzf +m --prompt="[file] > ")
        if [ -n "$result" ]; then
            LBUFFER="${LBUFFER}${result}"
        fi
        zle redisplay
    }
    zle -N select-file
    bindkey '^t' select-file

    # Open repo with <c-g>
    if command_exists tm; then
        # tm command: https://zenn.dev/layerx/articles/8c29b0367238b8
        bindkey -s '^g' 'tm\n'
    else
        # List repos under $(ghq root), including submodules.
        # Prunes at .git so we don't walk .git/modules/* (which is why `ghq list` is slow on repos with many submodules).
        function _ghq_fzf_build() {
            local root=$(ghq root)
            find -L "$root" -name .git -prune -print 2>/dev/null \
                | sed "s|/\.git$||; s|^${root}/||"
        }
        function _ghq_fzf() {
            local root=$(ghq root)
            local cache=${XDG_CACHE_HOME:-$HOME/.cache}/ghq-fzf-list
            [[ -f $cache ]] || { mkdir -p ${cache:h}; _ghq_fzf_build > $cache }
            local src=$(cat $cache | fzf --prompt "[ghq] > ")
            # Refresh in background if cache is older than 1h
            if [[ -z $(find "$cache" -mmin -60 2>/dev/null) ]]; then
                (_ghq_fzf_build > $cache.tmp && mv $cache.tmp $cache) &!
            fi
            zle redisplay
            if [ -n "$src" ]; then
                BUFFER="cd ${root}/${src}"
                zle accept-line
            fi
            zle -R -c
        }
        zle -N _ghq_fzf
        bindkey '^g' _ghq_fzf
        # Invalidate the fzf cache when repos are added/removed, so new clones show up immediately on the next <c-g>.
        function ghq() {
            command ghq "$@"
            local ret=$?
            case "$1" in
                get|clone|create|rm) rm -f ${XDG_CACHE_HOME:-$HOME/.cache}/ghq-fzf-list ;;
            esac
            return $ret
        }
    fi
    # cd (fzf + zoxide) with zz
    zz() {
        local dirpath=$(zoxide query -l | sed "s|$HOME|~|g" | fzf --prompt "> " --preview="eval echo {} | sed 's|~|$HOME|' | xargs eza -a --oneline --sort=ext")
        cd $(eval echo $(echo $dirpath | sed 's|~|$HOME|'))
    }
fi

# copy the previous command
ppp() {
    prev_cmd=$(history -n | tail -n 1)
    echo "\"$prev_cmd\" copied!"
    echo -n $prev_cmd | pbcopy
}

# colorlized man pages
man() {
    LESS_TERMCAP_md=$'\e[01;34m' \
    LESS_TERMCAP_me=$'\e[0m' \
    LESS_TERMCAP_se=$'\e[0m' \
    LESS_TERMCAP_so=$'\e[01;4;31m' \
    LESS_TERMCAP_ue=$'\e[0m' \
    LESS_TERMCAP_us=$'\e[01;36m' \
    command man "$@"
}


## git status
git-path() {
    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "This is not a git repository."
        return 1
    fi

    super_root=$(git rev-parse --show-superproject-working-tree 2>/dev/null)
    root=$(git rev-parse --show-toplevel 2>/dev/null)

    if [[ -n "$super_root" ]]; then
        echo $(basename $super_root)${root:${#super_root}}
    else
        echo $(basename $root)
    fi
}

g() {
    echo "root : $(git-path)"

    if ! git rev-parse --is-inside-work-tree >/dev/null 2>&1; then
        echo "This is not a git repository."
        return 1
    fi

    echo "name : $(git config user.name)"
    echo "email: $(git config user.email)"
}

# ssh
function ssh() {
  # Check HERDR_ENV before TMUX: herdr panes can inherit a stale $TMUX from
  # the environment the herdr server was started in (dead socket errors).
  if [[ -n $(printenv HERDR_ENV) ]] ; then
      # herdr has no select-pane equivalent, but each pane is its own
      # terminal: OSC 11 sets the background, OSC 111 restores the default.
      if [[ `echo $1 | grep -E 'prd|prod|production'` ]] ; then
          printf '\e]11;#330000\a'
      elif [[ `echo $1 | grep -E 'stg|staging'` ]] ; then
          printf '\e]11;#000033\a'
      fi

      command ssh "$@"
      local ssh_status=$?

      printf '\e]111\a'
      return $ssh_status
  elif [[ -n $(printenv TMUX) ]] ; then
      local pane_id=$(tmux display -p '#{pane_id}')
      local original_bg=$(tmux show-options -gqv pane-active-border-style | grep -o 'bg=[^,]*')

      if [[ `echo $1 | grep -E 'prd|prod|production'` ]] ; then
          tmux select-pane -P 'bg=#330000'
      elif [[ `echo $1 | grep -E 'stg|staging'` ]] ; then
          tmux select-pane -P 'bg=#000033'
      fi

      command ssh "$@"

      tmux select-pane -t $pane_id -P "$original_bg"
  else
      command ssh "$@"
  fi
}

# herdr: show the repo on each pane border so splits in one window are
# tellable apart (no per-pane border color API; the label is the border's
# one customizable element). Manual pane names suppress herdr's auto agent
# labels (claude etc.), so when an agent command launches, preexec bakes it
# into the label ("repo · claude") and precmd drops it again on exit.
# Renames go over the socket only when the label actually changes.
if [[ -n $(printenv HERDR_ENV) && -n $HERDR_PANE_ID ]] ; then
  _herdr_pane_label() {
      [[ $1 == $_herdr_label_current ]] && return
      _herdr_label_current=$1
      if [[ -n $1 ]] ; then
          herdr pane rename "$HERDR_PANE_ID" "$1" >/dev/null 2>&1
      else
          herdr pane rename "$HERDR_PANE_ID" --clear >/dev/null 2>&1
      fi
  }
  _herdr_repo_label() {
      local root=$(git rev-parse --show-toplevel 2>/dev/null)
      [[ -z $root || $root == $HOME ]] && return
      print -r -- "${root:t}"
  }
  _herdr_label_precmd() {
      _herdr_pane_label "$(_herdr_repo_label)"
  }
  _herdr_label_preexec() {
      case "$1" in
          claude*|codex*|copilot*|gemini*)
              local repo=$(_herdr_repo_label)
              _herdr_pane_label "${repo:+$repo · }${1%% *}"
              ;;
      esac
  }
  autoload -Uz add-zsh-hook
  add-zsh-hook precmd _herdr_label_precmd
  add-zsh-hook preexec _herdr_label_preexec
fi

